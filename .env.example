# micelio — Environment Variables Example
# Copy to .env.local and fill in values

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_ACCESS_TOKEN=<access-token>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SUPER_ADMINS=admin@example.com

# ── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key: 32 bytes as 64-char hex string
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=<64-char-hex>

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=<production-access-token>
MERCADOPAGO_WEBHOOK_SECRET=<webhook-secret-from-mp-dashboard>

# MercadoPago Sandbox (E2E tests only)
MERCADOPAGO_TEST_ACCESS_TOKEN=<sandbox-access-token>
MERCADOPAGO_TEST_CARD_NUMBER=5031755734530604
MERCADOPAGO_TEST_CARDHOLDER=APRO
MERCADOPAGO_TEST_EXPIRATION_MONTH=11
MERCADOPAGO_TEST_EXPIRATION_YEAR=30
MERCADOPAGO_TEST_CVV=123
MERCADOPAGO_TEST_DNI=12345678

# ── Upstash Rate Limiting (SKY-111) ──────────────────────────────────────────
# Create a Redis database at https://console.upstash.com
# Copy REST URL and token from the database dashboard
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-rest-token>

# ── Sentry (SKY-122) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=skywalking
SENTRY_PROJECT=micelio

# ── Micelio (AI Agents) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<anthropic-api-key>
PERPLEXITY_API_KEY=<perplexity-api-key>

# ── Nequi Conecta (Colombia push payment) ───────────────────────────────────
NEQUI_API_BASE_URL=https://api.nequi.com/payments/v2
NEQUI_SANDBOX_BASE_URL=https://api.sandbox.nequi.com/payments/v2
# Webhook uses per-tenant app_secret stored encrypted in tenants.secure_config.nequi.app_secret
# No platform-level NEQUI_WEBHOOK_SECRET — each merchant has their own Nequi Conecta account.
# Register https://micelio.skyw.app/api/webhooks/nequi in each merchant's Nequi Conecta portal.
# 0 = real API (production/sandbox), 1 = mock mode (stub responses, bypasses outbound SigV4 calls and inbound HMAC verification)
NEQUI_MOCK_MODE=0

# ── Feature Flags (env overrides — bypasses DB, for local dev) ─────────────
# Set to "true" to force-enable. Leave unset or set to "false" to use DB row.
# NEXT_PUBLIC_FEATURE_AUTHOR_LANDINGS=true   # Artistas dashboard feature
